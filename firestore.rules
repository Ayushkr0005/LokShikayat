rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Primitives
    // ===============================================================

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check - including the specific bootstrap email
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "ayushkr111999@gmail.com"
      );
    }

    function isOfficer(orgId) {
      // Officers must be in the organizations collection or have it in their profile
      // For simplicity and to avoid O(n) reads in lists, we check the user profile role
      // Note: In list operations, we prefer checking resource.data fields.
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && user.role == 'officer' && user.organizationId == orgId;
    }

    function isOrgAdmin(orgId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && user.role == 'admin' && user.organizationId == orgId;
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUser(data) {
      return (data.email == null || (data.email is string && data.email.size() < 256)) &&
             data.role in ['citizen', 'officer', 'admin'] &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() < 100)) &&
             data.createdAt is string;
    }

    function isValidComplaint(data) {
      return isValidId(data.authorId) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.status in ['submitted', 'in-review', 'in-progress', 'resolved', 'rejected'] &&
             data.priority in ['low', 'medium', 'high', 'critical'] &&
             data.category in ['Infrastructure', 'Sanitation', 'Traffic', 'Noise', 'Safety', 'Utilities', 'Environment', 'Other'] &&
             data.createdAt is string;
    }

    function isValidNotification(data) {
      return isValidId(data.userId) &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.type is string &&
             data.read is bool &&
             data.createdAt is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation of first profile. Email can be null for anonymous users.
      // Identity integrity: author/owner UID MUST match request.auth.uid
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && incoming().role == existing().role && incoming().organizationId == existing().organizationId)
      ) && isValidUser(incoming());
    }

    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /complaints/{complaintId} {
      // Hardening Path Variable
      allow get: if isSignedIn() && isValidId(complaintId) && (
        resource.data.authorId == request.auth.uid || 
        isAdmin() ||
        isOfficer(resource.data.organizationId) ||
        isOrgAdmin(resource.data.organizationId)
      );

      // Secure List Queries
      allow list: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        isAdmin() ||
        isOfficer(resource.data.organizationId)
      );

      allow create: if isSignedIn() && 
                    incoming().authorId == request.auth.uid &&
                    isValidComplaint(incoming());

      allow update: if isSignedIn() && (
        isAdmin() ||
        // Citizens can only cancel or update description if not resolved
        (resource.data.authorId == request.auth.uid && 
         existing().status == 'submitted' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'priority'])) ||
        // Tier 2: Officers can update status and sentiment
        (isOfficer(resource.data.organizationId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'sentiment', 'updatedAt']))
      ) && isValidComplaint(incoming());

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isValidId(notificationId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn(); // Systems create notifications
      allow update: if isOwner(existing().userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Managed via console
    }
  }
}
